---
import BlogLayout from '../../layouts/BlogLayout.astro'
import PostCard from '../../components/blog/PostCard.astro'
import { getCollection } from 'astro:content'

const allPosts = await getCollection('posts')
const posts = allPosts
  .sort((a, b) => +b.data.number - +a.data.number)
---

<BlogLayout
  title="Blog — Javier Silvestri"
  description="Articles about software development, engineering management, and things I'm learning."
>
  <div class="mx-auto max-w-6xl px-6 py-16">

    <!-- Header -->
    <div class="mb-12">
      <span class="font-mono text-sm text-accent tracking-widest uppercase">Blog</span>
      <h1 class="mt-2 font-display text-5xl md:text-7xl tracking-wide text-white">
        LATEST POSTS
      </h1>
      <div class="mt-4 h-px w-16 bg-gradient-to-r from-accent to-transparent" />
      <p class="mt-4 text-muted-2 text-base max-w-md">
        Notes, deep dives, and things I'm learning along the way.
      </p>
    </div>

    <!-- Grid -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map(({ slug, data }) => (
        <li class="h-full">
          {(data.ready as boolean) ? (
            <a href={`/posts/${slug}`} class="block h-full">
              <PostCard
                slug={slug}
                ready={data.ready as boolean}
                title={data.title}
                description={data.description}
                tags={data.tags as string[]}
                pubDate={data.pubDate as Date}
                index={data.number as number}
              />
            </a>
          ) : (
            <PostCard
              slug={slug}
              ready={data.ready as boolean}
              title={data.title}
              description={data.description}
              tags={data.tags as string[]}
              pubDate={data.pubDate as Date}
              index={data.number as number}
            />
          )}
        </li>
      ))}
    </ul>

    <!-- RSS link -->
    <div class="mt-16 flex items-center justify-center">
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 font-mono text-sm text-muted hover:text-accent transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        Subscribe via RSS
      </a>
    </div>
  </div>
</BlogLayout>
