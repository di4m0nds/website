---
// Custom cursor: dot + lagging ring. Desktop only. Zero deps.
// Adds data-magnetic support for magnetic button pull.
---

<!-- Dot: follows instantly -->
<div
  id="cur-dot"
  aria-hidden="true"
  class="pointer-events-none fixed z-[9998] h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent opacity-0 transition-opacity duration-300"
/>

<!-- Ring: follows with lerp lag -->
<div
  id="cur-ring"
  aria-hidden="true"
  class="pointer-events-none fixed z-[9997] h-9 w-9 -translate-x-1/2 -translate-y-1/2 rounded-full border border-accent/50 opacity-0 transition-opacity duration-300"
/>

<script is:inline>
  (function () {
    // Skip on touch-only devices
    if (window.matchMedia('(hover: none)').matches) return

    const dot  = document.getElementById('cur-dot')
    const ring = document.getElementById('cur-ring')
    if (!dot || !ring) return

    let mx = -200, my = -200
    let rx = -200, ry = -200
    let isHovering = false
    let isClicking = false
    let raf = null

    // Show on first move
    function show() {
      dot.style.opacity  = '1'
      ring.style.opacity = '1'
    }

    function tick() {
      // Lerp ring toward mouse
      rx += (mx - rx) * 0.14
      ry += (my - ry) * 0.14

      dot.style.left  = mx + 'px'
      dot.style.top   = my + 'px'
      ring.style.left = rx + 'px'
      ring.style.top  = ry + 'px'

      raf = requestAnimationFrame(tick)
    }

    window.addEventListener('mousemove', (e) => {
      mx = e.clientX
      my = e.clientY
      show()
    }, { passive: true })

    window.addEventListener('mousedown', () => {
      isClicking = true
      dot.style.transform  = 'translate(-50%,-50%) scale(0.6)'
      ring.style.transform = 'translate(-50%,-50%) scale(1.5)'
    })

    window.addEventListener('mouseup', () => {
      isClicking = false
      dot.style.transform  = ''
      ring.style.transform = ''
    })

    window.addEventListener('mouseleave', () => {
      dot.style.opacity  = '0'
      ring.style.opacity = '0'
    })

    // ── Magnetic + hover state for interactive elements ──────
    const MAGNETIC_SEL = '[data-magnetic], button, a, [role="option"], [role="button"]'
    let magnetTarget = null

    document.addEventListener('mouseover', (e) => {
      const el = e.target.closest(MAGNETIC_SEL)
      if (!el) return
      magnetTarget = el
      dot.style.transform   = 'translate(-50%,-50%) scale(2.5)'
      dot.style.background  = 'transparent'
      dot.style.border      = '1px solid var(--color-accent)'
      ring.style.transform  = 'translate(-50%,-50%) scale(0.4)'
      ring.style.opacity    = '0.3'
    })

    document.addEventListener('mouseout', (e) => {
      const el = e.target.closest(MAGNETIC_SEL)
      if (!el) return
      magnetTarget = null
      dot.style.transform  = ''
      dot.style.background = ''
      dot.style.border     = ''
      ring.style.transform = ''
      ring.style.opacity   = '1'
      // Reset magnetic elements
      el.style.transform  = ''
      el.style.transition = 'transform 0.4s var(--ease-spring)'
    })

    // Magnetic pull on mousemove
    document.addEventListener('mousemove', (e) => {
      if (!magnetTarget) return
      const rect = magnetTarget.getBoundingClientRect()
      const cx = rect.left + rect.width  / 2
      const cy = rect.top  + rect.height / 2
      const dx = e.clientX - cx
      const dy = e.clientY - cy
      const dist = Math.sqrt(dx * dx + dy * dy)
      const range = Math.max(rect.width, rect.height) * 0.8

      if (dist < range) {
        const pull = (1 - dist / range) * 0.35
        magnetTarget.style.transform  = 'translate(' + (dx * pull) + 'px,' + (dy * pull) + 'px)'
        magnetTarget.style.transition = 'transform 0.1s linear'
      }
    }, { passive: true })

    // Cleanup on page transitions
    document.addEventListener('astro:before-swap', () => {
      if (raf) cancelAnimationFrame(raf)
    })
    document.addEventListener('astro:page-load', () => {
      tick()
    })

    tick()
  })()
</script>

<style is:global>
  /* Hide native cursor on desktop when JS loads */
  @media (hover: hover) {
    html.cursor-ready * { cursor: none !important; }
  }
</style>

<script is:inline>
  // Add cursor-ready class after cursor initialises
  if (!window.matchMedia('(hover: none)').matches) {
    document.documentElement.classList.add('cursor-ready')
  }
</script>
