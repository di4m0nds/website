---
interface Props {
  hoverable?: boolean
  glow?: 'none' | 'accent' | 'cyan'
  padding?: string
  class?: string
}

const {
  hoverable = true,
  glow = 'none',
  padding = 'p-6',
  class: className = '',
} = Astro.props

const glowMap = {
  none:   '',
  accent: 'hover:glow-accent hover:border-accent/40',
  cyan:   'hover:glow-cyan hover:border-cyan/40',
}
---

<div
  class:list={[
    'rounded-2xl border backdrop-blur-sm',
    'bg-white/[0.06] border-white/[0.11]',
    hoverable && 'transition-all duration-300 hover:bg-white/[0.09] hover:border-white/[0.18]',
    glow !== 'none' && glowMap[glow],
    padding,
    className,
  ]}
>
  <slot />
</div>
