---
interface Props {
  tag: string       // e.g. "01", "02"
  title: string
  subtitle?: string
  align?: 'left' | 'center'
}

const { tag, title, subtitle, align = 'left' } = Astro.props
---

<div class:list={['mb-12 md:mb-16', align === 'center' && 'text-center']}>
  <!-- Tag / number -->
  <span class="font-mono text-sm font-medium text-accent tracking-widest uppercase">
    {tag}
  </span>

  <!-- Title -->
  <h2 class="mt-2 font-display text-5xl md:text-6xl lg:text-7xl tracking-wide text-white leading-none">
    {title}
  </h2>

  <!-- Divider line -->
  <div
    class:list={[
      'mt-4 h-px w-16 bg-gradient-to-r from-accent to-transparent',
      align === 'center' && 'mx-auto',
    ]}
  />

  <!-- Subtitle -->
  {subtitle && (
    <p class="mt-4 max-w-lg text-muted-2 text-base leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
