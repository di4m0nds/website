---
const navLinks = [
  { label: 'About', href: '/#about' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Projects', href: '/#projects' },
  { label: 'Skills', href: '/#skills' },
  { label: 'GitHub', href: '/#github' },
  { label: 'Blog', href: '/posts' }
]
---

<header
  id='navbar'
  class='fixed top-0 right-0 left-0 z-50 flex h-16 items-center justify-between px-6 transition-all duration-300 md:px-10'
>
  <!-- Logo -->
  <a
    href='/'
    class='font-display hover:text-accent text-2xl tracking-widest text-white transition-colors duration-200'
  >
    JS<span class='text-accent'>.</span>
  </a>

  <!-- Desktop nav -->
  <nav class='hidden items-center gap-1 md:flex' aria-label='Main navigation'>
    {
      navLinks.map(({ label, href }) => (
        <a
          href={href}
          class='text-muted-2 group relative px-4 py-2 text-sm transition-colors duration-200 hover:text-white'
        >
          {label}
          <span class='bg-accent absolute bottom-1 left-1/2 h-px w-0 -translate-x-1/2 transition-all duration-300 group-hover:w-3/4' />
        </a>
      ))
    }
  </nav>

  <!-- CTA -->
  <a
    href='/#about'
    class='glass border-border-2 text-accent hover:glow-accent hover:border-accent hidden items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium transition-all duration-300 md:inline-flex'
  >
    Hire me
    <svg
      width='12'
      height='12'
      viewBox='0 0 12 12'
      fill='none'
      aria-hidden='true'
    >
      <path
        d='M2 6h8M6 2l4 4-4 4'
        stroke='currentColor'
        stroke-width='1.5'
        stroke-linecap='round'
        stroke-linejoin='round'></path>
    </svg>
  </a>

  <!-- Mobile menu button -->
  <button
    id='mobile-menu-btn'
    class='flex flex-col gap-1.5 p-2 md:hidden'
    aria-label='Toggle menu'
    aria-expanded='false'
  >
    <span class='block h-px w-6 bg-current transition-all duration-300'></span>
    <span class='block h-px w-4 bg-current transition-all duration-300'></span>
    <span class='block h-px w-6 bg-current transition-all duration-300'></span>
  </button>
</header>

<!-- Mobile menu -->
<div
  id='mobile-menu'
  class='bg-bg/95 fixed inset-0 z-40 hidden flex-col items-center justify-center gap-8 backdrop-blur-xl'
>
  {
    navLinks.map(({ label, href }) => (
      <a
        href={href}
        class='mobile-nav-link font-display hover:text-accent text-4xl tracking-widest text-white transition-colors'
      >
        {label}
      </a>
    ))
  }
</div>

<script is:inline>
  const navbar = document.getElementById('navbar')
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')

  // Scroll: add glass bg when scrolled
  window.addEventListener(
    'scroll',
    () => {
      if (window.scrollY > 40) {
        navbar.classList.add('glass', 'border-b', 'border-border')
      } else {
        navbar.classList.remove('glass', 'border-b', 'border-border')
      }
    },
    { passive: true }
  )

  // Mobile toggle
  btn?.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden')
    menu.classList.toggle('flex', !isOpen)
    btn.setAttribute('aria-expanded', String(!isOpen))
  })

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      menu.classList.remove('flex')
      btn?.setAttribute('aria-expanded', 'false')
    })
  })
</script>
