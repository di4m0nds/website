---
import SectionHeader from '../ui/SectionHeader.astro'
import Badge from '../ui/Badge.astro'
import { experiences } from '../../data/portfolio'
---

<section id="experience" class="relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32">
  <SectionHeader
    tag="02 — Experience"
    title="WHERE I'VE WORKED"
  />

  <div class="relative">
    <!-- Timeline vertical line -->
    <div class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-accent via-border to-transparent" aria-hidden="true" />

    <div class="space-y-12">
      {experiences.map(({ role, company, date, type, location, tech, responsibilities, keyAccomplishments }, i) => (
        <div class="reveal relative pl-12 md:pl-16">
          <!-- Timeline dot -->
          <div class="absolute left-2.5 md:left-4 top-2 h-3 w-3 rounded-full border-2 border-accent bg-bg" aria-hidden="true" />

          <!-- Card -->
          <div class="glass rounded-2xl border border-border p-6 md:p-8 transition-all duration-300 hover:border-border-2 hover:bg-surface-2">
            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-6">
              <div>
                <h3 class="font-display text-2xl md:text-3xl tracking-wide text-white">
                  {role}
                </h3>
                <p class="mt-1 text-accent font-medium">{company}</p>
                <p class="mt-1 text-sm text-muted font-mono">
                  {type} · {location}
                </p>
              </div>
              <span class="shrink-0 font-mono text-sm text-muted glass px-3 py-1.5 rounded-full border border-border self-start">
                {date}
              </span>
            </div>

            <!-- Tech stack -->
            {tech && (
              <div class="flex flex-wrap gap-2 mb-6">
                {tech.map(t => (
                  <Badge label={t} variant="cyan" />
                ))}
              </div>
            )}

            <!-- Two columns: responsibilities + accomplishments -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h4 class="text-xs font-mono font-semibold text-accent tracking-widest uppercase mb-3">
                  Responsibilities
                </h4>
                <ul class="space-y-2">
                  {responsibilities.map(item => (
                    <li class="flex items-start gap-2 text-sm text-muted-2 leading-relaxed">
                      <span class="text-accent mt-1 shrink-0">▸</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <h4 class="text-xs font-mono font-semibold text-cyan tracking-widest uppercase mb-3">
                  Accomplishments
                </h4>
                <ul class="space-y-2">
                  {keyAccomplishments.map(item => (
                    <li class="flex items-start gap-2 text-sm text-muted-2 leading-relaxed">
                      <span class="text-cyan mt-1 shrink-0">✦</span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      ))}

      <!-- Open to opportunities indicator -->
      <div class="reveal relative pl-12 md:pl-16">
        <div class="absolute left-2.5 md:left-4 top-2 h-3 w-3 rounded-full border-2 border-muted bg-bg" aria-hidden="true" />
        <div class="glass rounded-2xl border border-dashed border-border p-6 flex items-center gap-4">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75" />
            <span class="relative inline-flex rounded-full h-3 w-3 bg-accent" />
          </span>
          <p class="text-muted-2 text-sm">
            <span class="text-white font-medium">Now</span> — Open to new opportunities
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
