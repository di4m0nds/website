---
import SectionHeader from '../ui/SectionHeader.astro'
import Badge from '../ui/Badge.astro'
import { experiences, education } from '../../data/portfolio'
---

<section
  id='experience'
  class='relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32'
>
  <SectionHeader tag='02 - Experience' title="WHERE I'VE WORKED" />

  <div class='relative'>
    <div
      class='from-accent via-border absolute top-0 bottom-0 left-4 w-px bg-gradient-to-b to-transparent md:left-6'
      aria-hidden='true'
    >
    </div>

    <div class='space-y-10'>
      {
        experiences.map(
          ({
            role,
            company,
            date,
            type,
            location,
            tech,
            responsibilities,
            keyAccomplishments
          }) => (
            <div class='reveal relative pl-12 md:pl-16'>
              <div
                class='border-accent bg-bg absolute top-2 left-2.5 h-3 w-3 rounded-full border-2 md:left-4.5'
                aria-hidden='true'
              />

              <div class='glass border-border hover:border-border-2 hover:bg-surface-2 rounded-2xl border p-6 transition-all duration-300 md:p-8'>
                <div class='mb-5 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between'>
                  <div>
                    <h3 class='font-display text-2xl tracking-wide text-white md:text-3xl'>
                      {role}
                    </h3>
                    <p class='text-accent mt-1 font-medium'>{company}</p>
                    <p class='text-muted mt-0.5 font-mono text-sm'>
                      {type} · {location}
                    </p>
                  </div>
                  <span class='text-muted glass border-border shrink-0 self-start rounded-full border px-3 py-1.5 font-mono text-sm'>
                    {date}
                  </span>
                </div>

                {tech && (
                  <div class='mb-5 flex flex-wrap gap-2'>
                    {tech.map((t) => (
                      <Badge label={t} variant='cyan' />
                    ))}
                  </div>
                )}

                <div class='grid grid-cols-1 gap-6 md:grid-cols-2'>
                  <div>
                    <h4 class='text-accent mb-3 font-mono text-xs font-semibold tracking-widest uppercase'>
                      Responsibilities
                    </h4>
                    <ul class='space-y-2'>
                      {responsibilities.map((item) => (
                        <li class='text-muted-2 flex items-start gap-2 text-sm leading-relaxed'>
                          <span class='text-accent mt-1 shrink-0'>&#9656;</span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h4 class='text-cyan mb-3 font-mono text-xs font-semibold tracking-widest uppercase'>
                      Accomplishments
                    </h4>
                    <ul class='space-y-2'>
                      {keyAccomplishments.map((item) => (
                        <li class='text-muted-2 flex items-start gap-2 text-sm leading-relaxed'>
                          <span class='text-cyan mt-1 shrink-0'>&#10022;</span>
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          )
        )
      }

      <!-- Open now indicator -->
      <div class='reveal relative pl-12 md:pl-16'>
        <div
          class='border-muted bg-bg absolute top-2 left-2.5 h-3 w-3 rounded-full border-2 md:left-4'
          aria-hidden='true'
        >
        </div>
        <div
          class='glass border-border flex items-center gap-4 rounded-2xl border border-dashed p-5'
        >
          <span class='relative flex h-3 w-3 shrink-0'>
            <span
              class='bg-accent absolute inline-flex h-full w-full animate-ping rounded-full opacity-75'
            ></span>
            <span class='bg-accent relative inline-flex h-3 w-3 rounded-full'
            ></span>
          </span>
          <p class='text-muted-2 text-sm'>
            <span class='font-medium text-white'>Now</span> — Open to new opportunities
            in Barcelona or remote
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Education -->
  <div class='mt-20'>
    <h3
      class='text-accent mb-8 font-mono text-xs font-semibold tracking-widest uppercase'
    >
      Education
    </h3>
    <div class='grid grid-cols-1 gap-4 sm:grid-cols-2'>
      {
        education.map(({ institution, degree, date, location, topics }) => (
          <div class='reveal glass border-border hover:border-border-2 rounded-2xl border p-6 transition-colors duration-300'>
            <p class='text-accent mb-2 font-mono text-xs tracking-widest uppercase'>
              {date}
            </p>
            <h4 class='font-display mb-1 text-xl tracking-wide text-white'>
              {institution}
            </h4>
            <p class='text-muted-2 mb-3 text-sm'>{degree}</p>
            <p class='text-muted font-mono text-xs'>{location}</p>
            {topics && (
              <div class='mt-3 flex flex-wrap gap-2'>
                {topics.map((t) => (
                  <span class='text-muted-2 glass border-border rounded-md border px-2 py-0.5 font-mono text-xs'>
                    {t}
                  </span>
                ))}
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
