---
import GlassCard from '../ui/GlassCard.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import { aboutInfo } from '../../data/portfolio'

const prompts = [
  { id: 'who',     label: 'Who are you?',     short: 'who_are_you' },
  { id: 'stack',   label: 'Tech stack?',       short: 'stack'       },
  { id: 'mindset', label: 'Your mindset?',     short: 'mindset'     },
  { id: 'goal',    label: 'What drives you?',  short: 'goal'        },
  { id: 'next',    label: 'What is next?',     short: 'next'        },
]

const responses: Record<string, string[]> = {
  who_are_you: [
    '> Javier Silvestri — Junior Software Developer.',
    '> Based in Barcelona, Spain. Originally from Argentina.',
    '> 1+ yr shipping production mobile & web apps.',
    '> Specialized in Flutter/Dart · React · TypeScript.',
    '> Available now — remote-first, open to hybrid.',
  ],
  stack: [
    '> Mobile:    Flutter (v2/v3) · Dart · Swift · Kotlin · React Native',
    '> State Mgmt: BLoC · Provider · GetX · Zustand · Redux',
    '> Frontend:  TypeScript · React · Next.js · Astro · Tailwind CSS',
    '> Backend:   Node.js · NestJS · Firebase · PostgreSQL · MongoDB',
    '> DevOps:    Git · Docker · GitHub Actions · CI/CD',
    '> AI-Assisted: GitHub Copilot · Claude · ChatGPT · Gemini',
  ],
  mindset: [
    '> "Code is read far more than it is written."',
    '> Clean architecture over clever hacks — every time.',
    '> Performance is a feature, not an afterthought.',
    '> Great UX hides complexity. Bad UX exposes it.',
    '> Ship, iterate, learn. Repeat.',
  ],
  goal: [
    '> Building apps that 50,000+ people actually use daily.',
    '> The feedback loop between code and real-world impact.',
    '> Bridging mobile and web — owning full product experiences.',
    '> Science + software: where I want to keep going.',
  ],
  next: [
    '> Deepening Flutter architecture — Clean Arch + TDD.',
    '> Expanding Swift/iOS skills for cross-platform reach.',
    '> Open source contributions to the Flutter ecosystem.',
    '> Growing into a developer who ships end-to-end products.',
  ],
}
---

<section id="about" class="relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32">
  <SectionHeader
    tag="01 — About"
    title="WHO AM I"
  />

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-14 items-start">

    <!-- ── Left: photo + stats ────────────────────────────── -->
    <div class="reveal flex flex-col items-center lg:items-start gap-8">
      <div class="relative group">
        <!-- Ambient glow -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent/30 to-cyan/20 blur-2xl transition-all duration-500 group-hover:blur-3xl group-hover:from-accent/40" />
        <!-- Rotating glitch ring -->
        <div class="absolute inset-[-3px] rounded-full border border-accent/20 glitch-border" aria-hidden="true" />
        <!-- Photo -->
        <div class="relative h-56 w-56 md:h-72 md:w-72 rounded-full overflow-hidden border border-border">
          <img
            src={aboutInfo.photo}
            alt="Javier Silvestri"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
          />
        </div>
        <!-- Location badge (replacing online badge) -->
        <span class="absolute bottom-3 right-3 flex items-center gap-1.5 rounded-full glass border border-border px-2.5 py-1 text-xs font-mono text-muted-2">
          <svg class="w-3 h-3 text-accent" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a5 5 0 0 0-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 0 0-5-5Zm0 6.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z"/></svg>
          Barcelona
        </span>
      </div>

      <!-- Quick stats -->
      <div class="grid grid-cols-2 gap-3 w-full max-w-xs">
        {[
          { val: '1+',  label: 'YRS EXP',   color: 'text-accent' },
          { val: '50K+',label: 'APP USERS',  color: 'text-accent' },
          { val: '20+', label: 'SKILLS',    color: 'text-cyan'   },
          { val: '∞',   label: 'COFFEE',    color: 'text-cyan'   },
        ].map(({ val, label, color }) => (
          <GlassCard padding="p-4" class="text-center" hoverable glow="none">