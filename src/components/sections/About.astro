---
import GlassCard from '../ui/GlassCard.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import { aboutInfo } from '../../data/portfolio'

const prompts = [
  { id: 'who',      label: 'Who are you?',          short: 'who_are_you' },
  { id: 'stack',    label: 'What is your stack?',   short: 'stack' },
  { id: 'mindset',  label: 'Your mindset?',         short: 'mindset' },
  { id: 'goal',     label: 'What drives you?',      short: 'goal' },
  { id: 'next',     label: 'What is next?',         short: 'next' },
]

const responses: Record<string, string[]> = {
  who_are_you: [
    '> Javier Silvestri — Software Developer based in San Luis, Argentina.',
    '> +1 year building web & mobile apps across frontend and backend teams.',
    '> I specialise in interfaces that feel fast, intuitive, and alive.',
    '> Currently open to junior/mid-level roles — remote or hybrid.',
  ],
  stack: [
    '> Primary: React · Next.js · Astro · TypeScript · Tailwind CSS',
    '> Backend: Node.js · Go · REST APIs · SQL · MongoDB · Redis',
    '> Mobile: Flutter · Dart',
    '> DevOps: Docker · Git · Linux',
    '> Always learning: whatever the next project demands.',
  ],
  mindset: [
    '> "Code is read far more than it is written."',
    '> I chase clarity over cleverness — every time.',
    '> Performance is a feature, not an afterthought.',
    '> Great UX hides complexity. Bad UX exposes it.',
    '> Shipping > perfecting. Iterate fast, learn faster.',
  ],
  goal: [
    '> Building things people actually use and enjoy.',
    '> The feedback loop between code and real impact.',
    '> Bridging design and engineering — where both sides win.',
    '> Growing into a developer who can own entire product experiences.',
  ],
  next: [
    '> Deepening systems design and backend architecture.',
    '> Open source contributions — giving back to the ecosystem.',
    '> Building a SaaS side project (stealth mode 👀)',
    '> Always: becoming a sharper, faster, more intentional engineer.',
  ],
}
---

<section id="about" class="relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32">
  <SectionHeader
    tag="01 — About"
    title="WHO AM I"
  />

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-14 items-start">

    <!-- ── Left: photo + stats ────────────────────────────── -->
    <div class="reveal flex flex-col items-center lg:items-start gap-8">
      <div class="relative group">
        <!-- Glow ring -->
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent/30 to-cyan/20 blur-2xl transition-all duration-500 group-hover:blur-3xl group-hover:from-accent/40" />
        <!-- Glitch border ring -->
        <div class="absolute inset-[-3px] rounded-full border border-accent/20 glitch-border" aria-hidden="true" />
        <div class="relative h-52 w-52 md:h-64 md:w-64 rounded-full overflow-hidden border border-border">
          <img
            src={aboutInfo.photo}
            alt="Javier Silvestri"
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
        </div>
        <!-- Online badge -->
        <span class="absolute bottom-3 right-3 flex items-center gap-1.5 rounded-full glass border border-border px-2.5 py-1 text-xs font-mono text-muted-2">
          <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse" />
          online
        </span>
      </div>

      <!-- Quick stats -->
      <div class="grid grid-cols-2 gap-3 w-full max-w-xs">
        {[
          { val: '1+',  label: 'YRS EXP',   color: 'text-accent' },
          { val: '4+',  label: 'PROJECTS',  color: 'text-accent' },
          { val: '18+', label: 'SKILLS',    color: 'text-cyan' },
          { val: '∞',   label: 'COFFEE',    color: 'text-cyan' },
        ].map(({ val, label, color }) => (
          <GlassCard padding="p-4" class="text-center" hoverable glow="none">
            <p class={`font-display text-3xl ${color}`}>{val}</p>
            <p class="text-xs text-muted mt-1 font-mono tracking-widest">{label}</p>
          </GlassCard>
        ))}
      </div>

      <!-- CV links -->
      <div class="flex gap-3 flex-wrap">
        <a href={aboutInfo.cvEn} tar