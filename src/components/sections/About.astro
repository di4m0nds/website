---
import SectionHeader from '../ui/SectionHeader.astro'
import { aboutInfo } from '../../data/portfolio'

const prompts = [
  { label: 'who am i',   key: 'who'     },
  { label: 'stack',      key: 'stack'   },
  { label: 'mindset',    key: 'mindset' },
  { label: 'motivation', key: 'goal'    },
  { label: 'next',       key: 'next'    },
]

const responses: Record<string, string[]> = {
  who: [
    "Hi — I'm Javier. Junior dev, 24 years old.",
    'Born in San Luis, Argentina. Relocated to Barcelona last year.',
    '2+ years building real apps — one has 50,000+ downloads on Play Store.',
    'I write Flutter by day, TypeScript by night, and drink too much coffee.',
    'Currently open to work — remote-first, hybrid also welcome.',
  ],
  stack: [
    'Mobile ——  Flutter · Dart (my main) · Swift/SwiftUI (learning)',
    'State   ——  BLoC · Provider · GetX · Zustand · Redux',
    'Web     ——  TypeScript · React · Next.js · Astro',
    'Backend ——  Node.js · NestJS · Firebase · PostgreSQL',
    'DevOps  ——  Git · Docker · GitHub Actions · CI/CD',
    'AI pair ——  Copilot · Claude · Gemini (daily drivers)',
  ],
  mindset: [
    "Code is read far more than it's written — I keep it clear.",
    "I'd rather ask a dumb question than build the wrong thing.",
    'Bugs are my fault until proven otherwise.',
    'No magic — understand the tool before reaching for it.',
    '"Done" means tested, not just not-crashing.',
  ],
  goal: [
    'Working on apps real people depend on daily.',
    'That 50k downloads number hits different than any side project.',
    'Bridging mobile and web — owning a product end to end.',
    'Long term: where software and science meet.',
  ],
  next: [
    'Going deeper on Clean Architecture + TDD in Flutter.',
    'Getting more serious about Swift/iOS alongside Flutter.',
    "Contributing to OSS — haven't done enough of that yet.",
    'Shipping something under my own name that people actually use.',
  ],
}
---

<section id='about' class='relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32'>
  <SectionHeader tag='01 — About' title='WHO AM I' />

  <div class='grid grid-cols-1 items-start gap-8 md:grid-cols-2 md:gap-10 lg:gap-16'>

    <!-- ── Left: photo + stats + CV ──────────────────────── -->
    <div class='reveal flex flex-col items-center gap-6 md:items-start'>

      <!-- Photo with ambient glow + rotating border + float -->
      <div class='photo-float group relative'>
        <div
          class='from-accent/30 to-cyan/20 group-hover:from-accent/50 absolute inset-0 rounded-full bg-gradient-to-br blur-2xl transition-all duration-700 group-hover:blur-3xl'
          aria-hidden='true'
        ></div>
        <div
          class='absolute inset-[-3px] rounded-full'
          style='background: conic-gradient(from 0deg, rgba(249,115,22,0.45), rgba(14,165,233,0.25), rgba(249,115,22,0.45)); animation: spin-slow 8s linear infinite;'
          aria-hidden='true'
        ></div>
        <div class='bg-bg absolute inset-[1px] rounded-full' aria-hidden='true'></div>
        <div class='border-border relative h-56 w-56 overflow-hidden rounded-full border md:h-64 md:w-64'>
          <img
            src={aboutInfo.photo}
            alt='Javier Silvestri'
            loading='lazy'
            decoding='async'
            class='h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-105'
          />
        </div>
        <span
          class='bg-black/80 border-border text-muted-2 absolute right-2 bottom-4 flex items-center gap-1.5 rounded-full border px-2.5 py-1 font-mono text-xs font-bold'
        >
          <svg class='text-accent h-3 w-3' viewBox='0 0 16 16' fill='currentColor'>
            <path d='M8 1a5 5 0 0 0-5 5c0 3.5 5 9 5 9s5-5.5 5-9a5 5 0 0 0-5-5Zm0 6.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z'></path>
          </svg>
          Barcelona, ES
        </span>
      </div>

      <!-- Stats grid -->
      <div class='grid w-full grid-cols-2 gap-3'>
        {
          [
            { val: '2+',   label: 'YRS EXP',      textColor: 'text-accent', lineColor: 'via-accent/60'  },
            { val: '50K+', label: 'APP USERS',     textColor: 'text-accent', lineColor: 'via-accent/60'  },
            { val: 'AI',   label: 'APPLICATIONS',  textColor: 'text-cyan',   lineColor: 'via-cyan/60'    },
            { val: '∞',    label: 'COFFEE',        textColor: 'text-cyan',   lineColor: 'via-cyan/60'    },
          ].map(({ val, label, textColor, lineColor }) => (
            <div class='stat-card group relative overflow-hidden rounded-xl p-5 text-center cursor-default'>
              <div class='absolute inset-0 rounded-xl border border-white/[0.10] bg-white/[0.05] transition-all duration-300 group-hover:bg-white/[0.09] group-hover:border-white/[0.18]'></div>
              <div class={`absolute bottom-0 inset-x-0 h-[2px] bg-gradient-to-r from-transparent ${lineColor} to-transparent opacity-50 transition-opacity duration-300 group-hover:opacity-90`}></div>
              <div class='relative z-10'>
                <p class={`font-display text-4xl tracking-wide ${textColor}`}>{val}</p>
                <p class='text-muted mt-1.5 font-mono text-[10px] tracking-widest'>{label}</p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- CV download -->
      <a
        href={aboutInfo.cvEn}
        target='_blank'
        rel='noopener noreferrer'
        data-magnetic
        class='glass border-border text-muted-2 hover:border-accent/50 group inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-mono text-sm transition-all duration-300 hover:text-white'
      >
        <svg class='text-accent h-4 w-4' viewBox='0 0 16 16' fill='none' stroke='currentColor' stroke-width='1.5'>
          <path d='M3 2h7l3 3v9H3V2Z'></path>
          <path d='M10 2v3h3'></path>
          <path d='M5 8h6M5 11h4'></path>
        </svg>
        Download CV
        <svg class='h-3 w-3 transition-transform group-hover:translate-y-0.5' viewBox='0 0 12 12' fill='none' stroke='currentColor' stroke-width='1.5'>
          <path d='M6 1v7M2 8l4 3 4-3'></path>
        </svg>
      </a>
    </div>

    <!-- ── Right: terminal ───────────────────────────────── -->
    <div
      class='reveal reveal-delay-2 border-border scanlines flex flex-col overflow-hidden rounded-2xl border'
      style='background: rgba(8,8,15,0.75); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);'
    >
      <!-- macOS chrome bar -->
      <div class='border-border flex items-center gap-2 border-b px-4 py-3 select-none' style='background: rgba(255,255,255,0.03);'>
        <button
          type='button'
          class='console-dot h-3 w-3 cursor-default rounded-full'
          style='background: #ff5f57; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.4);'
          aria-label='Close'
        ></button>
        <button
          type='button'
          class='console-dot h-3 w-3 cursor-default rounded-full'
          style='background: #ffbc2e; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.4);'
          aria-label='Minimize'
        ></button>
        <button
          type='button'
          class='console-dot h-3 w-3 cursor-default rounded-full'
          style='background: #28c840; box-shadow: 0 0 0 0.5px rgba(0,0,0,0.4);'
          aria-label='Fullscreen'
        ></button>
        <span class='text-muted ml-4 font-mono text-xs tracking-wider'>javier@portfolio:~</span>
        <span id='about-status' class='ml-auto font-mono text-[10px] text-green-400/60'>● READY</span>
      </div>

      <!-- Output area -->
      <div
        id='about-output'
        class='text-muted/80 min-h-[260px] max-h-[340px] flex-1 space-y-0.5 overflow-y-auto p-4 font-mono text-xs leading-5'
        aria-live='polite'
        aria-label='Terminal output'
      >
      </div>

      <!-- Prompt buttons -->
      <div class='border-border flex flex-wrap gap-2 border-t p-3'>
        {
          prompts.map(({ label, key }) => (
            <button
              type='button'
              data-key={key}
              class='about-btn border border-white/[0.10] bg-white/[0.03] text-muted hover:text-white hover:border-accent/40 hover:bg-accent/5 rounded-lg px-3.5 py-2 font-mono text-[11px] transition-all duration-200 active:scale-95'
            >
              <span class='text-accent/50 mr-1'>$</span>{label}
            </button>
          ))
        }
        <button
          type='button'
          id='about-clear'
          class='text-muted/40 hover:text-muted ml-auto rounded-lg px-3 py-2 font-mono text-[11px] transition-colors duration-200'
        >
          clear
        </button>
      </div>
    </div>

  </div>
</section>

<script is:inline define:vars={{ responsesJson: JSON.stringify(responses) }}>
  ;(function () {
    var RESP     = JSON.parse(responsesJson)
    var output   = document.getElementById('about-output')
    var status   = document.getElementById('about-status')
    var clearBtn = document.getElementById('about-clear')
    if (!output) return

    var activeTimer = null

    function cancelTyping() {
      clearTimeout(activeTimer)
      activeTimer = null
    }

    function typeInto(el, text, speed, onDone) {
      var i   = 0
      el.textContent = ''
      var cur = document.createElement('span')
      cur.className   = 'typing-cursor'
      cur.textContent = '█'
      el.appendChild(cur)
      function nextChar() {
        if (i < text.length) {
          cur.before(document.createTextNode(text[i++]))
          output.scrollTop = output.scrollHeight
          activeTimer = setTimeout(nextChar, Math.random() * 20 + speed)
        } else {
          cur.remove()
          output.scrollTop = output.scrollHeight
          if (onDone) onDone()
        }
      }
      nextChar()
    }

    function typeLines(lines, idx, cls) {
      if (idx >= lines.length) {
        setStatus('● READY', 'text-green-400/60')
        return
      }
      var p = appendEl('p', cls || 'text-muted-2/80')
      typeInto(p, lines[idx], 14, function () {
        activeTimer = setTimeout(function () { typeLines(lines, idx + 1, cls) }, 55)
      })
    }

    function appendEl(tag, cls) {
      var el = document.createElement(tag)
      el.className = cls
      output.appendChild(el)
      output.scrollTop = output.scrollHeight
      return el
    }

    function setStatus(text, colorCls) {
      status.textContent = text
      status.className   = 'ml-auto font-mono text-[10px] ' + colorCls
    }

    function setActiveButton(key) {
      document.querySelectorAll('.about-btn').forEach(function (btn) {
        var on = key && btn.dataset.key === key
        btn.classList.toggle('btn-active', !!on)
      })
    }

    function runPrompt(key) {
      cancelTyping()
      var lines = RESP[key]
      if (!lines) return
      setActiveButton(key)
      appendEl('p', '')
      var cmdEl = appendEl('p', 'text-accent/70')
      setStatus('● RUNNING', 'text-yellow-400/60')
      typeInto(cmdEl, '❯ ' + key.replace(/_/g, ' '), 28, function () {
        activeTimer = setTimeout(function () {
          appendEl('p', '')
          typeLines(lines, 0)
        }, 180)
      })
    }

    function boot() {
      var bootLines = [
        { text: 'javier.dev — session started',        cls: 'text-muted/40'    },
        { text: 'profile loaded ✓',                    cls: 'text-green-400/50' },
        { text: 'click a prompt below to learn more.', cls: 'text-cyan/60'     },
      ]
      function bootStep(i) {
        if (i >= bootLines.length) { appendEl('p', ''); return }
        var p = appendEl('p', bootLines[i].cls)
        typeInto(p, bootLines[i].text, 16, function () {
          activeTimer = setTimeout(function () { bootStep(i + 1) }, 100)
        })
      }
      bootStep(0)
    }
    boot()

    document.querySelectorAll('.about-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { runPrompt(btn.dataset.key) })
    })

    if (clearBtn) {
      clearBtn.addEventListener('click', function () {
        cancelTyping()
        output.innerHTML = ''
        setStatus('● READY', 'text-green-400/60')
        setActiveButton(null)
        boot()
      })
    }

    // macOS dots spring drag
    document.querySelectorAll('.console-dot').forEach(function (dot) {
      var isDown = false, startX, startY
      dot.addEventListener('mousedown', function (e) {
        isDown = true; startX = e.clientX; startY = e.clientY
        dot.style.transition = 'none'
        dot.style.transform  = 'scale(0.78)'
        e.preventDefault()
      })
      document.addEventListener('mousemove', function (e) {
        if (!isDown) return
        var dx = Math.max(-4, Math.min(4, (e.clientX - startX) * 0.35))
        var dy = Math.max(-4, Math.min(4, (e.clientY - startY) * 0.35))
        dot.style.transform = 'scale(0.88) translate(' + dx + 'px,' + dy + 'px)'
      })
      document.addEventListener('mouseup', function () {
        if (!isDown) return
        isDown = false
        dot.style.transition = 'transform 0.45s cubic-bezier(0.175,0.885,0.32,1.275)'
        dot.style.transform  = 'scale(1) translate(0,0)'
        setTimeout(function () { dot.style.transition = '' }, 450)
      })
    })
  })()
</script>

<style>
  /* Typing cursor blink */
  .typing-cursor {
    color: var(--color-accent);
    opacity: 1;
    animation: cur-blink 0.65s step-end infinite;
    font-size: 0.85em;
    vertical-align: baseline;
    line-height: 1;
  }
  @keyframes cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Thin scrollbar */
  #about-output::-webkit-scrollbar { width: 2px; }
  #about-output::-webkit-scrollbar-thumb { background: var(--color-accent); border-radius: 1px; }
  #about-output::-webkit-scrollbar-track { background: transparent; }

  /* Spinning ring on photo */
  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Photo float */
  @keyframes photo-float {
    0%, 100% { transform: translateY(0px);  }
    50%       { transform: translateY(-8px); }
  }
  .photo-float { animation: photo-float 5s ease-in-out infinite; }

  /* Dot interactions */
  .console-dot {
    transition: filter 0.15s ease, transform 0.15s ease;
    will-change: transform;
  }
  .console-dot:hover { filter: brightness(1.25); }

  /* Active prompt button */
  .about-btn.btn-active {
    border-color: rgba(249,115,22,0.55) !important;
    color: var(--color-accent) !important;
    background: rgba(249,115,22,0.10) !important;
  }
</style>
