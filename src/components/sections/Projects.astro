---
import SectionHeader from '../ui/SectionHeader.astro'
import Badge from '../ui/Badge.astro'
import { projects } from '../../data/portfolio'

// Serialise projects for client-side JS
const projectsJson = JSON.stringify(projects)
---

<section id="projects" class="relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32">
  <SectionHeader
    tag="03 — Projects"
    title="RECENT WORK"
    subtitle="Select a project to explore."
  />

  <!-- Terminal container -->
  <div class="reveal glass border border-border rounded-2xl overflow-hidden">

    <!-- Terminal chrome bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-surface">
      <span class="h-3 w-3 rounded-full bg-red-500/70" />
      <span class="h-3 w-3 rounded-full bg-yellow-500/70" />
      <span class="h-3 w-3 rounded-full bg-green-500/70" />
      <span class="ml-4 font-mono text-xs text-muted tracking-wider">
        projects.exe — Javier's Portfolio
      </span>
    </div>

    <!-- Terminal body: two panels -->
    <div class="flex flex-col md:flex-row min-h-[480px]">

      <!-- Left: project list -->
      <div class="md:w-64 shrink-0 border-b md:border-b-0 md:border-r border-border p-4">
        <p class="font-mono text-xs text-muted mb-3 tracking-widest">
          <span class="text-accent">~$</span> ls ./projects
        </p>
        <ul id="project-list" class="space-y-1" role="listbox" aria-label="Projects">
          {projects.map((p, i) => (
            <li
              role="option"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-id={p.id}
              class:list={[
                'project-tab flex items-center gap-2 px-3 py-2 rounded-lg cursor-pointer font-mono text-sm transition-all duration-200',
                i === 0
                  ? 'bg-accent/15 text-accent border border-accent/30'
                  : 'text-muted-2 hover:text-white hover:bg-surface-2 border border-transparent',
              ]}
            >
              <span class="text-accent shrink-0">▸</span>
              {p.name}
            </li>
          ))}
        </ul>

        <div class="mt-6 font-mono text-xs text-muted/50 space-y-0.5">
          <p>$ {projects.length} entries found</p>
          <p class="terminal-cursor text-muted/30">&nbsp;</p>
        </div>
      </div>

      <!-- Right: project detail -->
      <div class="flex-1 p-6 md:p-8 relative overflow-hidden">
        <!-- Ambient glow -->
        <div aria-hidden="true" class="absolute top-0 right-0 h-64 w-64 rounded-full bg-accent/3 blur-3xl pointer-events-none" />

        <div id="project-detail" class="relative z-10 h-full flex flex-col gap-6">
          <!-- Filled by JS -->
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Template for project detail (cloned by JS) -->
<template id="project-template">
  <div class="flex flex-col gap-4 h-full">
    <!-- Header line -->
    <div>
      <p class="font-mono text-xs text-muted mb-2">
        <span class="text-cyan">~/projects</span> $ cat README.md
      </p>
      <h3 class="font-display text-3xl md:text-4xl tracking-wide text-white project-name"></h3>
    </div>

    <!-- Description typed -->
    <div class="glass border border-border rounded-xl p-4 font-mono text-sm text-muted-2 leading-relaxed">
      <span class="text-accent">// </span>
      <span class="project-desc"></span>
    </div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 project-tags"></div>

    <!-- Year -->
    <p class="font-mono text-xs text-muted">
      <span class="text-cyan">year:</span> <span class="project-year"></span>
    </p>

    <!-- Spacer -->
    <div class="flex-1" />

    <!-- Links -->
    <div class="flex flex-wrap gap-3">
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="project-link group inline-flex items-center gap-2 rounded-full bg-accent px-5 py-2 text-sm font-semibold text-white transition-all duration-300 hover:bg-accent-hover hover:glow-accent"
      >
        View Live
        <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 14 14" fill="none">
          <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</template>

<script is:inline define:vars={{ projectsJson }}>
  const PROJECTS = JSON.parse(projectsJson)

  const list = document.getElementById('project-list')
  const detail = document.getElementById('project-detail')
  const tpl = document.getElementById('project-template')

  let activeId = PROJECTS[0]?.id
  let typeTimer = null

  function renderProject(p) {
    if (!detail || !tpl) return

    // Clone template
    const node = tpl.content.cloneNode(true)

    node.querySelector('.project-name').textContent = p.name
    node.querySelector('.project-year').textContent = p.year

    // Tags
    const tagsEl = node.querySelector('.project-tags')
    p.tags.forEach(tag => {
      const span = document.createElement('span')
      span.className =
        'inline-flex items-center rounded-full border border-cyan/30 bg-cyan-dim px-2.5 py-0.5 text-xs font-mono text-cyan'
      span.textContent = tag
      tagsEl.appendChild(span)
    })

    // Link
    node.querySelector('.project-link').href = p.href

    // Clear + insert
    detail.innerHTML = ''
    detail.appendChild(node)

    // Typewriter effect for description
    if (typeTimer) clearTimeout(typeTimer)
    const descEl = detail.querySelector('.project-desc')
    if (!descEl) return
    const text = p.description
    let i = 0
    descEl.textContent = ''
    function writeChar() {
      if (i < text.length) {
        descEl.textContent += text[i++]
        typeTimer = setTimeout(writeChar, 18)
      }
    }
    writeChar()
  }

  function setActive(id) {
    activeId = id
    // Update tab styles
    list.querySelectorAll('.project-tab').forEach(tab => {
      const isActive = tab.dataset.id === id
      tab.setAttribute('aria-selected', String(isActive))
      tab.classList.toggle('bg-accent/15', isActive)
      tab.classList.toggle('text-accent', isActive)
      tab.classList.toggle('border-accent/30', isActive)
      tab.classList.toggle('text-muted-2', !isActive)
      tab.classList.toggle('border-transparent', !isActive)
    })

    const project = PROJECTS.find(p => p.id === id)
    if (project) renderProject(project)
  }

  // Bind clicks
  list.querySelectorAll('.project-tab').forEach(tab => {
    tab.addEventListener('click', () => setActive(tab.dataset.id))
  })

  // Init with first project
  if (PROJECTS[0]) renderProject(PROJECTS[0])
</script>
