---
import SectionHeader from '../ui/SectionHeader.astro'
import { projects } from '../../data/portfolio'

// Console narration per project
const narration: Record<string, string[]> = {
  dosep: [
    'SYSTEM: Loading project manifest...',
    'INFO:   Stack resolved — Flutter · Dart · Firebase',
    'INFO:   Type: Government health service app (Android)',
    'INFO:   Scale: 50,000+ downloads on Google Play Store',
    'STATUS: Performance improved 30% — deployed LIVE ✓',
  ],
  sigem: [
    'SYSTEM: Connecting to government services API...',
    'INFO:   Stack resolved — Flutter · Dart · REST APIs',
    'INFO:   Type: City gov app — bookings & real-time tracking',
    'INFO:   Features: appointments, bus ETA, municipal permits',
    'STATUS: Bug-free restore from legacy codebase — LIVE ✓',
  ],
  chefco: [
    'SYSTEM: Loading project manifest...',
    'INFO:   Stack resolved — React · Tailwind · Node.js',
    'INFO:   Type: Full-stack e-commerce platform',
    'STATUS: Deployed to Netlify CDN — LIVE ✓',
  ],
  euge: [
    'SYSTEM: Mounting photography asset store...',
    'INFO:   Stack resolved — Astro · Tailwind · MDX',
    'INFO:   Type: Optimised image gallery + photography portfolio',
    'STATUS: Lighthouse score 98/100. Images optimised ✓',
  ],
}

const projectsJson  = JSON.stringify(projects)
const narrationJson = JSON.stringify(narration)
---

<section id="projects" class="relative z-10 mx-auto max-w-6xl px-6 py-24 md:py-32">
  <SectionHeader
    tag="03 — Projects"
    title="RECENT WORK"
    subtitle="Select a project to explore."
  />

  <div class="reveal glass border border-border rounded-2xl overflow-hidden scanlines">

    <!-- Chrome bar -->
    <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-surface select-none">
      <span class="h-2.5 w-2.5 rounded-full bg-red-500/70" />
      <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/70" />
      <span class="h-2.5 w-2.5 rounded-full bg-green-500/70" />
      <span class="ml-4 font-mono text-xs text-muted tracking-wider">
        projects.exe — Javier Silvestri
      </span>
      <span id="proj-status" class="ml-auto font-mono text-xs text-green-400/70">● READY</span>
    </div>

    <div class="flex flex-col md:flex-row min-h-[540px]">

      <!-- ── Left: project list ──────────────────────────── -->
      <div class="md:w-64 shrink-0 border-b md:border-b-0 md:border-r border-border p-4 flex flex-col gap-4">
        <p class="font-mono text-xs text-muted tracking-widest">
          <span class="text-accent">~$</span> ls ./projects
        </p>

        <ul id="project-list" class="space-y-1" role="listbox" aria-label="Projects">
          {projects.map((p, i) => (
            <li
              role="option"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-id={p.id}
              class:list={[
                'project-tab flex items-center gap-2 px-3 py-2 rounded-lg cursor-pointer font-mono text-xs transition-all duration-200',
                i === 0
                  ? 'bg-accent/15 text-accent border border-accent/30'
                  : 'text-muted-2 hover:text-white hover:bg-surface-2 border border-transparent',
              ]}
            >
              <span class="text-accent/60 shrink-0">▸</span>
              <span class="truncate">{p.name}</span>
              {p.featured && (
                <span class="ml-auto shrink-0 text-[9px] text-cyan/60 border border-cyan/20 rounded px-1">★</span>
              )}
            </li>
          ))}
        </ul>

        <div class="mt-auto font-mono text-[10px] text-muted/40 space-y-0.5 pt-4 border-t border-border">
          <p><span class="text-accent/50">$</span> {projects.length} entries</p>
          <p><span class="text-cyan/50">$</span> {projects.filter(p => p.featured).length} featured</p>
        </div>
      </div>

      <!-- ── Right: detail + console ────────────────────── -->
      <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Project detail -->
        <div id="project-detail" class="flex-1 p-5 md:p-7 relative overflow-hidden">
          <div aria-hidden="true"
            class="absolute top-0 right-0 h-48 w-48 rounded-full bg-accent/4 blur-3xl pointer-events-none transition-all duration-700" />
        </div>

        <!-- Console output -->
        <div class="border-t border-border bg-surface/50">
          <div class="flex items-center gap-2 px-4 py-2 border-b border-border/50">
            <span class="font-mono text-[10px] text-muted tracking-widest">CONSOLE</span>
            <span class="h-1.5 w-1.5 rounded-full bg-green-400/60 animate-pulse ml-auto" />
          </div>
          <div id="proj-console"
            class="h-32 overflow-y-auto p-3 font-mono text-[11px] space-y-0.5 text-muted/70">
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Detail template -->
<template id="project-template">
  <div class="flex flex-col gap-5 h-full">
    <div>
      <p class="font-mono text-[11px] text-cyan/70 mb-1.5 tracking-widest">cat README.md</p>
      <h3 class="font-display text-3xl md:text-4xl tracking-wide text-white project-name glitch" data-text=""></h3>
    </div>

    <p class="font-mono text-sm text-muted-2 leading-relaxed border-l-2 border-accent/30 pl-3 project-desc"></p>

    <div class="flex flex-wrap gap-2 project-tags"></div>

    <div class="flex items-center gap-4 text-xs font-mono text-muted mt-auto">
      <span>year: <span class="text-cyan project-year"></span></span>
      <span class="project-featured"></span>
    </div>

    <a href="#" target="_blank" rel="noopener noreferrer"
      data-magnetic
      class="project-link self-start inline-flex items-center gap-2 rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white
             transition-all duration-300 hover:bg-accent-hover hover:glow-accent group">
      View Live
      <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</template>

<script is:inline define:vars={{ projectsJson, narrationJson }}>
;(function () {
  var PROJECTS   = JSON.parse(projectsJson)
  var NARRATION  = JSON.parse(narrationJson)

  var list      = document.getElementById('project-list')
  var detail    = document.getElementById('project-detail')
  var console_  = document.getElementById('proj-console')
  var st